# =============================================================================
# Weekly Dev Summary — n8n Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# n8n will load these automatically when the server starts.

# ── GitHub ──────────────────────────────────────────────────────────────────
GITHUB_OWNER=my-organization
GITHUB_REPO=my-repo

# ── Output Channel ──────────────────────────────────────────────────────────
# One of: slack, email, discord
OUTPUT_CHANNEL=slack

# ── Slack (if OUTPUT_CHANNEL=slack) ─────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/xxxxxxxx
SLACK_CHANNEL=#dev-summaries

# ── Email / SMTP (if OUTPUT_CHANNEL=email) ──────────────────────────────────
EMAIL_TO=team@example.com
EMAIL_FROM=dev-summary@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_SECURE=false

# ── Discord (if OUTPUT_CHANNEL=discord) ─────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/000000/xxxxxxxxxx
