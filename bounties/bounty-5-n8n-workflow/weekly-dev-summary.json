    {
      "id": "c9d0e1f2-a3b4-5678-2345-789012345678",
      "name": "Extract Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1400, 300],
      "parameters": {
        "jsCode": "const response = $input.first().json;\nlet summary = '';\nif (response.content && Array.isArray(response.content)) {\n  summary = response.content.map(c => c.text || '').filter(Boolean).join('\\n');\n} else if (response.completion) {\n  summary = response.completion;\n} else if (response.error) {\n  summary = 'Error from Claude API: ' + JSON.stringify(response.error);\n} else {\n  try {\n    summary = JSON.stringify(response, null, 2);\n  } catch(e) {\n    summary = 'Could not parse Claude API response';\n  }\n}\nreturn [{ json: { summary } }];"
      }
    },
