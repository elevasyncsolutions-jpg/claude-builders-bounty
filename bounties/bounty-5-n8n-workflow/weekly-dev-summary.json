    {
      "id": "a7b8c9d0-e1f2-3456-0123-567890123456",
      "name": "Build Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1050, 300],
      "parameters": {
        "jsCode": "function safeItems(nodeName) {\n  try {\n    return $node[nodeName].all() || [];\n  } catch(e) {\n    return [];\n  }\n}\n\nconst since = $node['Prepare Config'].json['since'];\nconst owner = $node['Prepare Config'].json['owner'];\nconst repo = $node['Prepare Config'].json['repo'];\n\nfunction isRealPR(p) {\n  const j = p.json;\n  return j && j.number && j.title && j.html_url && j.node_id;\n}\n\nfunction isRealIssue(i) {\n  const j = i.json;\n  return j && j.number && j.title && !j.pull_request;\n}\n\nfunction isRealCommit(c) {\n  const j = c.json;\n  return j && j.sha && j.commit && j.commit.author;\n}\n\nconst rawCommits = safeItems('Get Commits').filter(isRealCommit);\nconst sinceDate = new Date(since);\nconst allPRs = safeItems('Get PRs').filter(isRealPR);\nconst relevantPRs = allPRs.filter(p => new Date(p.json.created_at) >= sinceDate);\nconst rawIssues = safeItems('Get Issues').filter(isRealIssue);\nconst relevantIssues = rawIssues.filter(i => new Date(i.json.created_at) >= sinceDate);\n\nfunction truncate(msg, len) {\n  if (!msg) return '';\n  return msg.length > len ? msg.substring(0, len) + '...' : msg;\n}\n\nconst commitLines = rawCommits.map(c => {\n  const d = c.json;\n  const msg = (d.commit.message || '').split('\\n')[0];\n  const author = d.commit.author ? d.commit.author.name || d.author?.login || 'unknown' : 'unknown';\n  const sha = d.sha ? d.sha.substring(0, 7) : '';\n  return `  - ${author}: ${truncate(msg, 80)} (${sha})`;\n}).join('\\n') || '  (none in this period)';\n\nconst prLines = relevantPRs.map(p => {\n  const d = p.json;\n  const status = d.merged_at ? 'merged' : (d.state === 'closed' ? 'closed without merge' : 'open');\n  return `  - [#${d.number}] ${d.title} — ${d.user?.login || 'unknown'} (${status})`;\n}).join('\\n') || '  (none in this period)';\n\nconst issueLines = relevantIssues.map(i => {\n  const d = i.json;\n  return `  - [#${d.number}] ${d.title} — ${d.user?.login || 'unknown'} (${d.state})`;\n}).join('\\n') || '  (none in this period)';\n\nconst mergedPRs = relevantPRs.filter(p => p.json.merged_at);\nconst openPRs = relevantPRs.filter(p => p.json.state === 'open');\nconst closedIssues = relevantIssues.filter(i => i.json.state === 'closed');\nconst openIssues = relevantIssues.filter(i => i.json.state === 'open');\n\nconst prompt = `You are a technical lead writing a concise weekly development summary for your team.\n\nRepository: ${owner}/${repo}\nPeriod: ${since.split('T')[0]} to this Monday\n\n## Stats Overview\n- Commits: ${rawCommits.length}\n- Pull Requests: ${relevantPRs.length} (merged: ${mergedPRs.length}, open: ${openPRs.length})\n- Issues: ${relevantIssues.length} (closed: ${closedIssues.length}, open: ${openIssues.length})\n\n## Commits (${rawCommits.length})\n${commitLines}\n\n## Pull Requests (${relevantPRs.length})\n${prLines}\n\n## Issues (${relevantIssues.length})\n${issueLines}\n\nPlease write a professional weekly summary covering:\n1. **Highlights** — key changes, milestones, and notable achievements\n2. **Commits Breakdown** — who contributed and which areas of the codebase changed\n3. **PR Activity** — review velocity, merge rate, and notable PRs\n4. **Issue Activity** — new bugs filed, features requested, items resolved\n5. **Action Items** — stale PRs needing review, unreviewed issues, potential blockers\n\nUse markdown formatting. Keep it concise but informative. Write in a professional, encouraging tone.`;\n\nreturn [{\n  json: {\n    prompt,\n    stats: {\n      totalCommits: rawCommits.length,\n      totalPRs: relevantPRs.length,\n      totalIssues: relevantIssues.length,\n      mergedPRs: mergedPRs.length,\n      openPRs: openPRs.length,\n      closedIssues: closedIssues.length,\n      openIssues: openIssues.length\n    },\n    owner,\n    repo,\n    since\n  }\n}];"
      }
    },
    {
      "id": "b8c9d0e1-f2a3-4567-1234-678901234567",
      "name": "Claude API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1250, 300],
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "jsonBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "claude-sonnet-4-20250514"
            },
            {
              "name": "max_tokens",
              "value": 2048
            },
            {
              "name": "messages",
              "value": [
                {
                  "role": "user",
                  "content": "={{ $node['Build Summary'].json['prompt'] }}"
