    {
      "id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
      "name": "Prepare Config",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [450, 300],
      "parameters": {
        "jsCode": "const now = new Date();\nconst day = now.getDay();\nconst diff = day === 0 ? 6 : day - 1;\nconst lastMonday = new Date(now);\nlastMonday.setDate(now.getDate() - diff - 7);\nconst thisMonday = new Date(now);\nthisMonday.setDate(now.getDate() - diff);\nconst owner = ($env.GITHUB_OWNER || process.env.GITHUB_OWNER || '').trim();\nconst repo = ($env.GITHUB_REPO || process.env.GITHUB_REPO || '').trim();\nif (!owner || !repo) {\n  throw new Error('GITHUB_OWNER and GITHUB_REPO environment variables must be set');\n}\nreturn [{\n  json: {\n    since: lastMonday.toISOString(),\n    until: thisMonday.toISOString(),\n    owner,\n    repo\n  }\n}];"
      }
    },
